# Copy this file to .env.local and fill in real values from your Supabase
# project's dashboard: Project Settings > API.
#
# .env.local is gitignored (.gitignore: `.env*`) — never commit real values.
# Only the anon/public key belongs here; NEVER put the service_role key or
# database password in a file the app ships to the browser.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
